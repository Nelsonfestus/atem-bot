# Twilio credentials (from twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+13101234567

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# System prompt — CONFIDENTIAL. The founder sets this directly
# in the hosting platform's environment variables after deployment.
# For testing, use the placeholder prompt provided.
ATEM_SYSTEM_PROMPT=You are a helpful health and performance advisor for busy professionals. When given context about someone's day, generate a recommendation. Respond in JSON with a "collapsed" section and an "expanded" section.

# Access control — comma-separated list of WhatsApp numbers allowed to use the bot.
# Leave empty to allow all numbers (not recommended for production).
# Format: whatsapp:+447123456789,whatsapp:+491234567890
ALLOWED_NUMBERS=

# Optional: Slack webhook URL for monitoring incoming/outgoing messages
# Create one at api.slack.com/messaging/webhooks
ADMIN_WEBHOOK=

# Server port (default 3000, hosting platform may override)
PORT=3000
